{{
    config(
        enabled = false
    )
}}

/*
    vld_3 — per-column statistics for {{BASE_NAME}}
    Generated by the dbt-data-audit skill on {{GENERATED_DATE}}.
    Output: for each column in column_list, counts of:
              perfect match / both null / null in a only / null in b only / missing from a / missing from b / values differ
    {{FILTER_NOTE}}
    Scope : keep column_list short (problem columns from vld_2). Long lists produce long queries that may exceed warehouse limits.
    Next  : use models/audit_helper/patterns.md to diagnose and apply legacy-side fixes inside old_query, then re-run.
*/

{% set old_query %} -- Legacy (A)
{{LEGACY_QUERY}}
{% endset %}

{% set new_query %} -- New (B)
{{NEW_QUERY}}
{% endset %}

{% set column_list = [
{{COLUMNS_LIST}}
{{EXCLUDED_COLUMNS_BLOCK}}
] %}

{% for column in column_list %}

    (
        {{ audit_helper.compare_column_values(
            a_query = old_query,
            b_query = new_query,
            primary_key = "{{PRIMARY_KEY}}",
            column_to_compare = column
        ) }}
    )

    {% if not loop.last %}
        union all
    {% endif %}

{% endfor %}
